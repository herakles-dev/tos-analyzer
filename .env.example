# ─── Gemini API ────────────────────────────────────────────────
# Get your key at https://ai.google.dev/
GEMINI_API_KEY="your-gemini-api-key-here"

# ─── Database (PostgreSQL) ─────────────────────────────────────
# Quick start: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=dev postgres:15-alpine
DATABASE_URL="postgresql://postgres:dev@localhost:5432/tos_analyzer?schema=tos_analyzer"

# ─── Redis ─────────────────────────────────────────────────────
# Quick start: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL="redis://localhost:6379"

# ─── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SALT="generate-a-random-string-here"

# ─── Application ───────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Rate Limiting ─────────────────────────────────────────────
# Max analysis requests per IP per minute
RATE_LIMIT_PER_MINUTE=10

# ─── Budget Protection ─────────────────────────────────────────
# Gemini tokens per day. 5M tokens ~ $10-15/day max spend.
# Set to 0 to disable budget limits (not recommended in production).
DAILY_TOKEN_BUDGET=5000000

# ─── Analytics ─────────────────────────────────────────────────
ANALYTICS_ENABLED=true

# ─── PDF Processing ────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
